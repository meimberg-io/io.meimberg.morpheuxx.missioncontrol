# Mission Control — Production environment
# Copy this to deploy/.env.prod on the server and fill in secrets.

NODE_ENV=production
NEXT_PUBLIC_APP_ENV=prod

# MICO-9: Access protection is handled at the Traefik proxy layer via Basic Auth.
# MC_BASIC_AUTH_USERS is NOT a container env var — it must be available to Docker Compose
# at stack-up time via the shell or a .env file in the working directory.
# See docs/deploy/runbook.md → "Access protection (Basic Auth)" for setup instructions.
